# Copy to .env and fill in. NEVER commit the real .env.

# --- Supabase (service-role key — full write access, keep secret) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Garmin Connect (going-forward cardio source) ---
# Only used by bootstrap_login.py the first time; CI uses the cached token.
GARMIN_TOKENSTORE=~/.garminconnect
# Garmin takes over the day after your one-time Strava export backfill, so the
# two sources don't overlap. tools/import_strava_export.py prints the exact date.
SYNC_START_DATE=2026-06-17

# --- Weightlifting source ---
# Preferred: a Google Sheet published as CSV (File -> Share -> Publish to web -> CSV).
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXX/pub?gid=0&single=true&output=csv

# Alternative (only if SHEET_CSV_URL is unset): Google Keep via master token.
# KEEP_EMAIL=you@example.com
# KEEP_MASTER_TOKEN=aas_et/...       # from: python -m scraper.bootstrap_login keep
# KEEP_LABEL=Workout                  # only notes with this label are parsed
